APP_NAME=CodeBricks
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- Database ---
# For quick local testing you can switch DB_CONNECTION to sqlite and
# just set DB_DATABASE=database/database.sqlite (see README "Quick Start").
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=codebricks
DB_USERNAME=root
DB_PASSWORD=

# --- Session / Cache / Queue (defaults are fine for local dev) ---
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- JWT Auth (php-open-source-saver/jwt-auth) ---
# Generate with: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# --- CORS ---
# Comma-separated list of allowed frontend origins. Use * only for local dev.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Mail (optional, only needed if you wire up email notifications) ---
MAIL_MAILER=log
